# ============================================================
# 서울AI플랫폼 기사 자동 스크랩 시스템 — 환경변수 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# --- 서울AI플랫폼 로그인 정보 ---
SEOULAI_LOGIN_ID=your_id_here
SEOULAI_LOGIN_PW=your_password_here

# --- 사이트 URL ---
SEOULAI_BASE_URL=https://seoulai.saif.or.kr
SEOULAI_LOGIN_URL=https://seoulai.saif.or.kr/hmpg/user/logi/login.do
SEOULAI_LIST_URL=https://seoulai.saif.or.kr/hmpg/bpst/bpstListPage.do

# --- 수집 필터 ---
# 쉼표 구분으로 여러 값 지정 가능 (예: 정부부처·청·위원회,서울특별시)
SCRAPE_FILTER_HMPG_NM=정부부처·청·위원회

# --- 파일 경로 ---
OUTPUT_DIR=output
OUTPUT_FILENAME=articles_daily.xlsx
AUTH_DIR=auth
AUTH_STATE_FILE=storage_state.json
LOG_DIR=logs

# --- Playwright 옵션 ---
HEADLESS=true
BROWSER_TIMEOUT=30000
PAGE_LOAD_DELAY=2
ARTICLE_FETCH_DELAY=3

# --- 서버 설정 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- 타임존 ---
TIMEZONE=Asia/Seoul
